{
  "manifest_version": 3,
  "name": "waigdt",
  "version": "1.0",
  "description": "What am I gonna do today",
  "permissions": ["storage"],
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "waigdt@mustansir.dev",
      "strict_min_version": "109.0"
    }
  },
  "web_accessible_resources": [{
    "resources": ["assets/*"],
    "matches": ["<all_urls>"]
  }],
  "icons": {
  "16": "assets/favicon.svg",
  "32": "assets/favicon.svg",
  "48": "assets/favicon.svg",
  "128": "assets/favicon.svg"
}
}